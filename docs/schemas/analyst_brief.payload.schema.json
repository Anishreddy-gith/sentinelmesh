{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sentinelmesh.io/schemas/analyst_brief.payload.schema.json",
  "title": "analyst_briefs payload (DRAFT)",
  "$comment": "DRAFT — finalised in Phase 7 (analyst brief generation). Skeleton only.",
  "type": "object",
  "required": ["detection_id", "brief_text", "mitre_technique_id", "mitre_tactic", "confidence", "generated_by"],
  "properties": {
    "detection_id": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
    },
    "brief_text": { "type": "string", "minLength": 1, "maxLength": 4096 },
    "mitre_technique_id": {
      "type": "string",
      "pattern": "^T[0-9]{4}(\\.[0-9]{3})?$|^T0000$",
      "$comment": "MITRE ATT&CK technique or sub-technique ID; T0000 reserved for 'unmapped'."
    },
    "mitre_tactic": { "type": "string", "minLength": 1, "maxLength": 64 },
    "mitre_technique_name": { "type": "string", "minLength": 1, "maxLength": 128 },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "generated_by": {
      "type": "string",
      "$comment": "e.g. 'bart-base/template-fallback', 't5-small/finetuned-v1'"
    }
  }
}
