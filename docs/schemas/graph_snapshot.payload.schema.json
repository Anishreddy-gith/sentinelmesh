{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sentinelmesh.io/schemas/graph_snapshot.payload.schema.json",
  "title": "graph_snapshots payload (DRAFT)",
  "$comment": "DRAFT — field-level types finalised in Phase 3. The envelope contract is frozen at schema_version 1.0.0; only the payload shape is draft.",
  "type": "object",
  "required": ["window_start", "window_end", "nodes", "edges", "node_count", "edge_count"],
  "properties": {
    "window_start": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{3}Z$"
    },
    "window_end": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{3}Z$"
    },
    "nodes": {
      "type": "array",
      "items": { "type": "object", "$comment": "host node shape finalised in Phase 3" }
    },
    "edges": {
      "type": "array",
      "items": { "type": "object", "$comment": "edge shape finalised in Phase 3" }
    },
    "node_count": { "type": "integer", "minimum": 0 },
    "edge_count": { "type": "integer", "minimum": 0 },
    "contributing_trace_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
      },
      "$comment": "Reserved slot per docs/SCHEMA.md §3 rule 4 (fan-in picks one trace_id, lists the rest here)."
    }
  }
}
