{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sentinelmesh.io/schemas/processed_event.payload.schema.json",
  "title": "processed_events payload",
  "description": "Canonical, vendor-neutral 5-tuple event derived from a single raw_logs message. See docs/SCHEMA.md §2.2.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "ts",
    "src_ip",
    "dst_ip",
    "protocol",
    "bytes_sent",
    "bytes_recv",
    "alert_flag",
    "sensor_id",
    "source"
  ],
  "properties": {
    "ts": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{3}Z$",
      "description": "Canonical event timestamp (RFC3339 UTC ms)."
    },
    "src_ip": { "$ref": "#/$defs/IpAddress" },
    "dst_ip": { "$ref": "#/$defs/IpAddress" },
    "src_port": {
      "oneOf": [{ "$ref": "#/$defs/Port" }, { "type": "null" }],
      "description": "Null for ICMP or when the source vendor omits it."
    },
    "dst_port": {
      "oneOf": [{ "$ref": "#/$defs/Port" }, { "type": "null" }]
    },
    "protocol": { "$ref": "#/$defs/Protocol" },
    "bytes_sent": {
      "type": "integer",
      "minimum": 0,
      "description": "src->dst payload bytes. Zero if unknown."
    },
    "bytes_recv": {
      "type": "integer",
      "minimum": 0,
      "description": "dst->src payload bytes. Zero if unknown."
    },
    "packets_sent": { "type": ["integer", "null"], "minimum": 0 },
    "packets_recv": { "type": ["integer", "null"], "minimum": 0 },
    "duration_ms": { "type": ["integer", "null"], "minimum": 0 },
    "alert_flag": {
      "type": "boolean",
      "description": "True iff event indicates a flagged condition. Rule: Suricata log_type=='alert' OR Zeek conn_state in {S0,REJ,RSTR,RSTO}."
    },
    "alert_signature": { "type": ["string", "null"], "maxLength": 256 },
    "alert_category": { "type": ["string", "null"], "maxLength": 128 },
    "conn_state": { "type": ["string", "null"], "maxLength": 8 },
    "community_id": { "type": ["string", "null"], "maxLength": 64 },
    "sensor_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{0,63}$"
    },
    "source": { "type": "string", "enum": ["zeek", "suricata"] }
  },
  "$defs": {
    "IpAddress": {
      "type": "string",
      "pattern": "^([0-9]{1,3}(\\.[0-9]{1,3}){3}|[0-9a-fA-F:]+)$",
      "minLength": 3,
      "maxLength": 45
    },
    "Port": {
      "type": "integer",
      "minimum": 0,
      "maximum": 65535
    },
    "Protocol": {
      "type": "string",
      "enum": ["tcp", "udp", "icmp", "other"]
    }
  }
}
