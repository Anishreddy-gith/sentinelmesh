{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sentinelmesh.io/schemas/raw_log.payload.schema.json",
  "title": "raw_logs payload",
  "description": "Discriminated union of Zeek conn-style records and Suricata eve.json records. Variant is selected on the `source` field. See docs/SCHEMA.md §2.1.",
  "oneOf": [
    { "$ref": "#/$defs/ZeekRawLog" },
    { "$ref": "#/$defs/SuricataRawLog" }
  ],
  "$defs": {
    "ZeekRawLog": {
      "title": "Zeek raw log",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source", "log_type", "sensor_id", "received_at", "raw",
        "id_orig_h", "id_orig_p", "id_resp_h", "id_resp_p", "proto"
      ],
      "properties": {
        "source": { "const": "zeek" },
        "log_type": {
          "type": "string",
          "description": "Vendor-native log family. Zeek: 'conn'|'dns'|'http'|'ssl'|...",
          "minLength": 1,
          "maxLength": 32
        },
        "sensor_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]{0,63}$",
          "description": "Stable sensor instance identifier."
        },
        "received_at": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{3}Z$",
          "description": "Sensor-side event timestamp, normalised to RFC3339 UTC ms."
        },
        "raw": {
          "type": "object",
          "description": "Verbatim vendor row, preserved for forensic replay.",
          "minProperties": 1
        },
        "uid": { "type": ["string", "null"], "minLength": 1, "maxLength": 64 },
        "id_orig_h": { "$ref": "#/$defs/IpAddress" },
        "id_orig_p": { "$ref": "#/$defs/Port" },
        "id_resp_h": { "$ref": "#/$defs/IpAddress" },
        "id_resp_p": { "$ref": "#/$defs/Port" },
        "proto": { "$ref": "#/$defs/Protocol" },
        "service": { "type": ["string", "null"], "maxLength": 32 },
        "duration": { "type": ["number", "null"], "minimum": 0 },
        "orig_bytes": { "type": ["integer", "null"], "minimum": 0 },
        "resp_bytes": { "type": ["integer", "null"], "minimum": 0 },
        "conn_state": { "type": ["string", "null"], "maxLength": 8 },
        "history": { "type": ["string", "null"], "maxLength": 64 },
        "orig_pkts": { "type": ["integer", "null"], "minimum": 0 },
        "resp_pkts": { "type": ["integer", "null"], "minimum": 0 },
        "local_orig": { "type": ["boolean", "null"] },
        "local_resp": { "type": ["boolean", "null"] }
      }
    },
    "SuricataRawLog": {
      "title": "Suricata raw log",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source", "log_type", "sensor_id", "received_at", "raw",
        "src_ip", "dest_ip", "proto"
      ],
      "properties": {
        "source": { "const": "suricata" },
        "log_type": {
          "type": "string",
          "description": "Vendor-native log family. Suricata: 'flow'|'alert'|'dns'|'http'|'tls'|'fileinfo'.",
          "minLength": 1,
          "maxLength": 32
        },
        "sensor_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]{0,63}$"
        },
        "received_at": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{3}Z$"
        },
        "raw": {
          "type": "object",
          "minProperties": 1
        },
        "flow_id": { "type": ["integer", "null"], "minimum": 0 },
        "src_ip": { "$ref": "#/$defs/IpAddress" },
        "src_port": { "oneOf": [{ "$ref": "#/$defs/Port" }, { "type": "null" }] },
        "dest_ip": { "$ref": "#/$defs/IpAddress" },
        "dest_port": { "oneOf": [{ "$ref": "#/$defs/Port" }, { "type": "null" }] },
        "proto": { "$ref": "#/$defs/Protocol" },
        "community_id": { "type": ["string", "null"], "maxLength": 64 },
        "bytes_toserver": { "type": ["integer", "null"], "minimum": 0 },
        "bytes_toclient": { "type": ["integer", "null"], "minimum": 0 },
        "pkts_toserver": { "type": ["integer", "null"], "minimum": 0 },
        "pkts_toclient": { "type": ["integer", "null"], "minimum": 0 },
        "alert_signature_id": { "type": ["integer", "null"], "minimum": 0 },
        "alert_signature": { "type": ["string", "null"], "maxLength": 256 },
        "alert_category": { "type": ["string", "null"], "maxLength": 128 },
        "alert_severity": { "type": ["integer", "null"], "minimum": 1, "maximum": 5 }
      }
    },
    "IpAddress": {
      "type": "string",
      "description": "IPv4 dotted-quad or IPv6 string. Lenient pattern; strict parsing happens in code.",
      "pattern": "^([0-9]{1,3}(\\.[0-9]{1,3}){3}|[0-9a-fA-F:]+)$",
      "minLength": 3,
      "maxLength": 45
    },
    "Port": {
      "type": "integer",
      "minimum": 0,
      "maximum": 65535
    },
    "Protocol": {
      "type": "string",
      "enum": ["tcp", "udp", "icmp", "other"]
    }
  }
}
